# Nimble (data spine) — https://nimbleway.com / online.nimbleway.com
# Account Settings → API Keys → Create key (shown once)
NIMBLE_API_KEY=

# InsForge (backend + model gateway) — account-specific values from InsForge CLI/dashboard
INSFORGE_API_KEY=
INSFORGE_PROJECT_URL=
INSFORGE_GATEWAY_URL=
INSFORGE_GATEWAY_KEY=

# Kylon (execution) — optional for local send path (pak_...)
# Hackathon setup is primarily in-app: channel + secret + Gmail connection
# Credit link: https://app.kylon.io/c/q_rBaZ_kIMG8yUdV2FpiISm-rfosOZkj
KYLON_API_KEY=

# Band (coordination) — per-agent creds live in agent_config.yaml
BAND_CONFIG=agent_config.yaml

# LLM provider key (if calling a model directly instead of via gateway)
ANTHROPIC_API_KEY=
